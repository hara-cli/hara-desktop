{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hara",
  "version": "0.1.18",
  "identifier": "com.nanhara.hara",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Hara",
        "width": 1100,
        "height": 760,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/hara"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "macOS": {
      "hardenedRuntime": true,
      "entitlements": "Entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/hara-cli/hara-desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdBQzUwMzgwMjg4QTg4NkQKUldSdGlJb29nQVBGZWsyN1ROVGZvZ1o2N1hjdkRQQ2ZZc2pRZ0N6WFBPeC83ejR1TFJNRUY1WGcK"
    }
  }
}
