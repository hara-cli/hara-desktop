{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "pet-chat",
  "description": "Event-only bridge for the focusable Hara companion chat; the main window owns the engine and permissions",
  "windows": [
    "pet-chat"
  ],
  "permissions": [
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:event:allow-emit-to",
    "core:window:allow-start-dragging"
  ]
}
